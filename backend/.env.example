# SQLite 数据库文件路径（相对于 backend 目录，默认 ../data/warehouse.db）
SQLITE_PATH=./data/warehouse.db

# 服务监听端口（默认 3000）
PORT=3000

# 运行环境 development / production / test
NODE_ENV=development

# JWT 密钥（生产环境务必修改为强随机字符串）
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# 日志级别 error / warn / info / http / debug
LOG_LEVEL=info

# CORS 允许的来源（逗号分隔），未设置时允许所有来源（适合纯内网部署）
# 例如：CORS_ORIGIN=http://localhost:3001,http://192.168.1.10:3001
# CORS_ORIGIN=
