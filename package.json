{
  "name": "warehouse-management",
  "version": "1.0.0",
  "description": "仓库管理系统",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"cd backend && npm run dev -- --port 3000\" \"cd frontend && npm run dev -- --port 5176\"",
    "build": "cd frontend && npm run build",
    "init-db": "cd database && ./init.sh",
    "test": "cd backend && npm run test",
    "test:unit": "cd backend && npm run test:unit",
    "test:integration": "cd backend && npm run test:integration",
    "test:coverage": "cd backend && npm run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:automated": "node test/automated_test_runner.js"
  },
  "keywords": [
    "warehouse",
    "management",
    "system"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^9.0.0",
    "supertest": "^6.3.4"
  }
}
